rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNGSI BANTUAN (HELPER FUNCTIONS) ---

    // 1. Cek apakah user sudah login
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. Cek apakah user mengakses datanya sendiri
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 3. Mengambil data user dari database untuk cek role
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 4. Cek apakah user adalah Admin atau Developer
    function isAdmin() {
      return isSignedIn() && (
        getUserData().role == 'admin' || 
        getUserData().role == 'developer'
      );
    }

    // 5. Cek Role Manajemen (Admin, Guru, Staf, Kepsek, Wali Kelas, Ketua Kelas)
    function isStaffOrTeacher() {
      return isSignedIn() && (
        isAdmin() || 
        getUserData().role == 'Guru' || 
        getUserData().role == 'Staf' ||
        getUserData().role == 'Wali Kelas' ||
        getUserData().role == 'Ketua Kelas' ||
        getUserData().role == 'kepala_madrasah'
      );
    }

    // --- ATURAN PER KOLEKSI (COLLECTION RULES) ---

    // 1. USERS (Profil Pengguna)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isStaffOrTeacher();
      allow delete: if isAdmin();
    }

    // 2. STUDENTS (Data Induk Siswa)
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow update: if isStaffOrTeacher() || (isSignedIn() && resource.data.linkedUserId == request.auth.uid);
      allow create, delete: if isStaffOrTeacher();
    }

    // 3. TEACHERS (Data Guru)
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }

    // 4. CLASSES & ACADEMIC YEARS & SETTINGS
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }
    match /academic_years/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }
    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }

    // 5. ATTENDANCE (Presensi)
    match /attendance/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update, delete: if isStaffOrTeacher();
    }

    // 6. SCHEDULES (Jadwal)
    match /schedules/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }

    // 7. LETTERS (Layanan Surat)
    match /letters/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStaffOrTeacher() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isStaffOrTeacher() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'Pending');
    }

    // 8. AKADEMIK (Tugas, Nilai, Jurnal)
    match /assignments/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }
    match /grades/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }
    match /journals/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }

    // 9. KEUANGAN & INVENTARIS
    match /payments/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }
    match /inventory/{id} {
      allow read: if isSignedIn();
      allow write: if isStaffOrTeacher();
    }

    // 10. SYSTEM LOGS
    match /login_logs/{id} {
      allow create: if isSignedIn();
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update, delete: if false; 
    }
    
    // Cek Koneksi (Ping)
    match /system_check/{id} {
      allow read, write: if true;
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}