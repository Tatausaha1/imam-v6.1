
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fungsi pembantu untuk verifikasi login
    function isSignedIn() {
      return request.auth != null;
    }

    // Koleksi Users: User bisa baca data semua user (untuk linking), tapi hanya bisa tulis datanya sendiri
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId);
    }

    // Koleksi Data Induk: Izinkan pembacaan untuk semua pengguna terdaftar
    // Penulisan dibatasi untuk Admin/Guru di aplikasi, tapi di level rules kita berikan akses login dahulu
    match /students/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /teachers/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /classes/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /attendance/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /letters/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /academic_years/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /schedules/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /login_logs/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
    }

    // Aturan global fallback
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
